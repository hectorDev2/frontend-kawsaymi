## Backend base URL
# Local backend:
# NEXT_PUBLIC_API_URL=http://localhost:3000
# Render (prod):
NEXT_PUBLIC_API_URL=https://kawsaymi-care-backend.onrender.com

## Use mock API (demo)
# When true, ignores NEXT_PUBLIC_API_URL and uses the localStorage mock.
NEXT_PUBLIC_USE_MOCK=false

## Optional: Groq API key for Next.js /api/ai-* demo routes
# NOTE: The real RAG flow should use backend /knowledge/* endpoints.
# GROQ_API_KEY=...
